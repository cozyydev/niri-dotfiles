#!/usr/bin/env bash

defaults_dir="$HOME/.config/apps/defaults"
browser_file="$defaults_dir/browser"

if [[ -f "$browser_file" ]]; then
  browser_exec="$(<"$browser_file")"
else
  browser_exec="chromium"
fi

case "$browser_exec" in
google-chrome | google-chrome-stable | brave | brave-browser | chromium | \
  microsoft-edge | microsoft-edge-stable | opera | vivaldi | \
  vivaldi-stable | helium | helium-browser | helium-browser-bin)
  ;;
*)
  browser_exec="chromium"
  ;;
esac

browser_args=()

case "$browser_exec" in
helium | helium-browser-bin)
  browser_exec="helium-browser"
  browser_args=(
    --enable-features=WebUIDarkMode
    --force-dark-mode
  )
  ;;
helium-browser)
  browser_args=(
    --enable-features=WebUIDarkMode
    --force-dark-mode
  )
  ;;
esac

exec setsid "$browser_exec" "${browser_args[@]}" --app="$1" "${@:2}"
